{
    "build": {
      "nixpacks": {
        "config": {
          "phases": {
            "setup": {
              "nixPkgs": [
                "nodejs-18.x",  
                "python3"      
              ]
            },
            "install": {
              "cmds": [
                "npm cache clean --force",
                "rm -rf node_modules",   
                "npm install --legacy-peer-deps --force",
                "npm audit fix --force" 
              ]
            },
            "build": {
              "cmds": [
                "npm run build"
              ]
            }
          }
        }
      },
      "cache": {
        "paths": [
          "node_modules", 
          ".npm"
        ]
      }
    },
    "deploy": {
      "startCommand": "npm run start" 
    }
  }